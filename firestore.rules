rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasOnlyAllowedFields(['username', 'elo_rating', 'avg_accuracy', 'marker_theme', 'created_at']) &&
             validStringLength('username', 3, 30) &&
             request.resource.data.elo_rating is number &&
             request.resource.data.avg_accuracy is number &&
             request.resource.data.marker_theme in ['standard', 'retro', 'neon', 'minimalist'] &&
             request.resource.data.created_at is string;
    }

    function isValidFriendship() {
      return hasOnlyAllowedFields(['user_id_1', 'user_id_2', 'status']) &&
             request.resource.data.user_id_1 is string &&
             request.resource.data.user_id_2 is string &&
             request.resource.data.status in ['pending', 'accepted'];
    }

    function isValidMatch() {
      return hasOnlyAllowedFields(['status', 'winner_id', 'started_at', 'ended_at']) &&
             request.resource.data.status in ['waiting', 'in_progress', 'completed', 'abandoned'] &&
             (request.resource.data.winner_id == null || request.resource.data.winner_id is string) &&
             request.resource.data.started_at is string;
    }

    function isValidMatchPlayer() {
      return hasOnlyAllowedFields(['match_id', 'user_id', 'player_role', 'elo_change', 'accuracy_score']) &&
             request.resource.data.match_id is string &&
             request.resource.data.user_id is string &&
             request.resource.data.player_role in ['X', 'O'] &&
             (request.resource.data.elo_change == null || request.resource.data.elo_change is number) &&
             (request.resource.data.accuracy_score == null || request.resource.data.accuracy_score is number);
    }

    function isValidMove() {
      return hasOnlyAllowedFields(['match_id', 'user_id', 'move_number', 'super_grid_index', 'sub_grid_index', 'heuristic_delta']) &&
             request.resource.data.match_id is string &&
             request.resource.data.user_id is string &&
             request.resource.data.move_number is number &&
             request.resource.data.super_grid_index is number &&
             request.resource.data.sub_grid_index is number &&
             request.resource.data.heuristic_delta is number;
    }

    function isValidChatRoom() {
      return hasOnlyAllowedFields(['type', 'participants']) &&
             request.resource.data.type in ['global', 'direct', 'match'] &&
             request.resource.data.participants is list &&
             request.resource.data.participants.size() <= 100;
    }

    function isValidMessage() {
      return hasOnlyAllowedFields(['room_id', 'sender_id', 'sender_name', 'content', 'sent_at']) &&
             request.resource.data.room_id is string &&
             request.resource.data.sender_id is string &&
             validStringLength('sender_name', 1, 50) &&
             validStringLength('content', 1, 1000) &&
             request.resource.data.sent_at is string;
    }

    // ===============================================================
    // Collections
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated(); // Public profiles for leaderboard/matches
      allow create: if isOwner(userId) && isValidUser() && request.resource.data.elo_rating == 1200;
      allow update: if isOwner(userId) && isValidUser() && 
                    request.resource.data.elo_rating == resource.data.elo_rating && // Only server can update Elo
                    request.resource.data.avg_accuracy == resource.data.avg_accuracy && // Only server can update accuracy
                    request.resource.data.created_at == resource.data.created_at;
    }

    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.user_id_1 || request.auth.uid == resource.data.user_id_2);
      allow create: if isAuthenticated() && isValidFriendship() && 
                    (request.auth.uid == request.resource.data.user_id_1 || request.auth.uid == request.resource.data.user_id_2);
      allow update: if isAuthenticated() && isValidFriendship() && 
                    (request.auth.uid == resource.data.user_id_1 || request.auth.uid == resource.data.user_id_2) &&
                    request.resource.data.user_id_1 == resource.data.user_id_1 &&
                    request.resource.data.user_id_2 == resource.data.user_id_2;
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated();
      // Only server creates/updates matches
      allow create, update: if false; 
    }

    match /match_players/{matchPlayerId} {
      allow read: if isAuthenticated();
      // Only server creates/updates match_players
      allow create, update: if false;
    }

    match /moves/{moveId} {
      allow read: if isAuthenticated();
      // Only server creates/updates moves
      allow create, update: if false;
    }

    match /chat_rooms/{roomId} {
      allow read: if isAuthenticated() && (resource.data.type == 'global' || request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && isValidChatRoom() && 
                    (request.resource.data.type == 'global' || request.auth.uid in request.resource.data.participants);
      allow update: if isAuthenticated() && isValidChatRoom() && 
                    (resource.data.type == 'global' || request.auth.uid in resource.data.participants) &&
                    request.resource.data.type == resource.data.type;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated(); // We could restrict by room, but keeping it simple for now
      allow create: if isAuthenticated() && isValidMessage() && request.auth.uid == request.resource.data.sender_id;
      allow update: if false; // Messages are immutable
    }
  }
}
